{
  "site": {
    "title": "auto-refine demo",
    "tagline": "Optimize bounded artifacts against a trusted evaluator — and keep only the changes that survive cost, latency, safety, and hype constraints.",
    "proofNote": "This page is generated from actual auto-refine run summaries plus a thin narrative metadata layer. Most examples are deterministic proof tasks, and the issue-triage benchmark is backed by public `cli/cli` issue excerpts with source URLs. The metrics, decisions, artifacts, and kept/discarded outcomes all come from real runs."
  },
  "whatGetsOptimized": [
    {
      "label": "Bounded artifact",
      "value": "A file or policy you allow the system to change",
      "detail": "Examples: a prompt file, a routing policy, a scoring rubric, a config, or even repo-owned marketing copy."
    },
    {
      "label": "Trusted evaluator",
      "value": "A command that produces measurable results",
      "detail": "The evaluator decides quality, latency, cost, safety, or any other metrics you care about."
    },
    {
      "label": "Objective + constraints",
      "value": "Improve one thing without breaking the others",
      "detail": "Higher quality is not enough if the candidate is slower, pricier, unsafe, or overhyped."
    },
    {
      "label": "Rollback-safe loop",
      "value": "Bad candidates are discarded and reverted",
      "detail": "The incumbent only advances on accepted improvements."
    }
  ],
  "decisionRules": [
    {
      "title": "KEEP",
      "tag": "good candidate",
      "body": "A candidate is kept only when it improves the primary metric and still satisfies all hard constraints."
    },
    {
      "title": "DISCARD",
      "tag": "too expensive / too slow / unsafe / too hypey",
      "body": "A candidate is rejected even if it looks stronger on the primary metric, when it violates cost, latency, safety, or credibility rules."
    },
    {
      "title": "ROLLBACK",
      "tag": "incumbent stays clean",
      "body": "After a discard, the mutable artifact is restored to the last accepted incumbent. The bad trial does not linger."
    }
  ],
