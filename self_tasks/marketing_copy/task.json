{
  "name": "self-refine-marketing-copy",
  "task_root": "../..",
  "mutable_paths": [
    "marketing/hero.md"
  ],
  "baseline_command": [
    "python3",
    "self_tasks/marketing_copy/scripts/evaluate.py"
  ],
  "proposer_command": [
    "python3",
    "self_tasks/marketing_copy/scripts/proposer.py"
  ],
  "trial_command": [
    "python3",
    "self_tasks/marketing_copy/scripts/evaluate.py"
  ],
  "objective": {
    "primary_metric": "quality_score",
    "direction": "maximize",
    "constraints": [
      {"metric": "latency_ms", "op": "<=", "value": 2200},
      {"metric": "cost_usd", "op": "<=", "value": 0.02},
      {"metric": "hype_flags", "op": "==", "value": 0}
    ]
  },
  "iterations": 4,
  "output_dir": "runs/self-refine-marketing"
}
